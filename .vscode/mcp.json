{
	"servers": {
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			]
		},
		"com.atlassian/atlassian-mcp-server": {
			"type": "http",
			"url": "https://mcp.atlassian.com/v1/mcp"
		},
		"com.postman/postman-mcp-server": {
			"type": "http",
			"url": "https://mcp.postman.com/mcp",
			"headers": {
				"Authorization": "${input:PostmanApiKey}"
			}
		}
	},
	"inputs": [
		{
			"id": "PostmanApiKey",
			"type": "promptString",
			"description": "Postman API key — get it from Postman > Settings > API Keys. Format: Bearer <your-api-key>",
			"password": true
		}
	]
}
