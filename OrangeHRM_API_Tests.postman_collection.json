{
  "info": {
    "name": "OrangeHRM API Tests",
    "description": "Comprehensive API test collection for OrangeHRM (opensource-demo.orangehrmlive.com).\n\nModules covered:\n  1 - Authentication\n  2 - Employee Management (PIM)\n  3 - Leave Management\n  4 - Recruitment\n  5 - Admin\n  6 - Time & Attendance\n\nHow to use:\n  1. Import this file into Postman (File > Import).\n  2. Run '1 - Authentication / Login - Get Token' first — it auto-sets {{token}}.\n  3. Run remaining folders in order, or use the Collection Runner.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://opensource-demo.orangehrmlive.com/web/index.php/api/v2",
      "description": "OrangeHRM API v2 base URL"
    },
    {
      "key": "username",
      "value": "Admin"
    },
    {
      "key": "password",
      "value": "admin123"
    },
    {
      "key": "token",
      "value": "",
      "description": "JWT token — set automatically by the Login request"
    },
    {
      "key": "employeeId",
      "value": "7",
      "description": "Employee ID used across PIM and Time & Attendance tests"
    },
    {
      "key": "leaveTypeId",
      "value": "",
      "description": "Set automatically by Get Leave Types"
    },
    {
      "key": "vacancyId",
      "value": "1",
      "description": "Set automatically by Get Job Vacancies"
    },
    {
      "key": "candidateId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response time under 5000ms', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1 - Authentication",
      "description": "Login and session management. Run 'Login - Get Token' first — it stores {{token}} for all subsequent requests.",
      "item": [
        {
          "name": "Login - Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains token', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.have.property('token');",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  console.log('Token stored successfully');",
                  "});",
                  "",
                  "pm.test('Response has expected structure', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('data');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/validate",
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "description": "Authenticates with OrangeHRM using username/password and stores the returned JWT token in the {{token}} collection variable. This must be run before any other request."
          }
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Has user data', function () {",
                  "  pm.expect(pm.response.json()).to.have.property('data');",
                  "});",
                  "",
                  "pm.test('Content-Type is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/core/users/1",
            "description": "Retrieves the user profile for the Admin (user ID 1)."
          }
        }
      ]
    },
